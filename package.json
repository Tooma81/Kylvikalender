{
  "name": "kylvikalender",
  "version": "1.0.0",
  "description": "Veebipõhine külvikalender aiatööde planeerimiseks",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "install-all": "npm install && cd client && npm install",
    "scrape": "node -e \"require('./server/scraper.js')().catch(console.error)\""
  },
  "keywords": [
    "külvikalender",
    "aiakalender",
    "planting-calendar"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.91.1",
    "axios": "^1.13.3",
    "body-parser": "^1.20.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "puppeteer": "^24.36.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
