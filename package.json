{
  "name": "kylvikalender",
  "version": "1.0.0",
  "description": "Veebipõhine külvikalender aiatööde planeerimiseks",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "npm start --prefix client",
    "install-all": "npm install && npm run install:client",
    "setup": "npm run install-all",
    "install:client": "npm install --prefix client",
    "scrape": "node -e \"require('./server/scraper.js')().catch(console.error)\""
  },
  "keywords": [
    "külvikalender",
    "aiakalender",
    "planting-calendar"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "axios": "^1.7.0",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "puppeteer": "^24.36.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
